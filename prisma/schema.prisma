generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  role            String
  emailVerifiedAt DateTime?
  emailVerificationTokenHash String?
  emailVerificationSentAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  buyerProfile    BuyerProfile?
  providerProfile ProviderProfile?

  @@index([email])
  @@index([role])
}

model BuyerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String
  company   String?
  phone     String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  jobs      Job[]

  @@index([userId])
  @@index([city])
}

model ProviderProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String
  companyName    String?
  phone          String?
  city           String?
  bio            String?
  averageRating  Float    @default(0)
  completedJobs  Int      @default(0)
  primaryService String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobs           Job[]    @relation("JobProvider")
  offers         Offer[]
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([city])
  @@index([averageRating, completedJobs], map: "ProviderProfile_rating_jobs_idx")
}

model Job {
  id          String           @id @default(cuid())
  buyerId     String
  providerId  String?
  title       String
  description String
  category    String
  city        String
  budgetMin   Int?
  budgetMax   Int?
  status      String           @default("open")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  buyer       BuyerProfile     @relation(fields: [buyerId], references: [id])
  provider    ProviderProfile? @relation("JobProvider", fields: [providerId], references: [id])
  offers      Offer[]

  @@index([buyerId])
  @@index([providerId])
  @@index([status])
  @@index([category])
  @@index([city])
  @@index([createdAt])
}

model Offer {
  id         String          @id @default(cuid())
  jobId      String
  providerId String
  price      Int
  note       String?
  status     String          @default("pending")
  createdAt  DateTime        @default(now())
  job        Job             @relation(fields: [jobId], references: [id])
  provider   ProviderProfile @relation(fields: [providerId], references: [id])

  @@index([jobId])
  @@index([providerId])
  @@index([status])
}

model Message {
  id             String    @id @default(cuid())
  jobId          String
  senderId       String
  receiverId     String
  text           String
  attachmentUrl  String?
  attachmentType String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([jobId])
  @@index([senderId])
  @@index([receiverId])
  @@index([readAt])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
